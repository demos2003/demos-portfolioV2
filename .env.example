# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin login credentials for /admin
# Run: node scripts/hash-password.mjs <your-password>
# It prints a ready-to-paste "ADMIN_PASSWORD_HASH=..." line -- paste it below
# as-is, unquoted. (Next.js's env loader expands unescaped $ in values as
# variable references, which corrupts a raw bcrypt hash; quoting the value
# does NOT protect it, only escaping each $ as \$ does -- the script does
# this escaping for you.)
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Random string used to sign admin session cookies, e.g.: openssl rand -base64 32
SESSION_SECRET=
